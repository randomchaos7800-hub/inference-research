#!/usr/bin/env bash
set -euo pipefail

CODEX_BIN="/snap/codex/34/bin/codex"
HOME_ROOT="/home/dino"
CODEX_HOME_ROOT="/home/dino/snap/codex/34"
CITADEL_ROOT="/home/dino/citadel"
CITADEL_PROTOCOL="/home/dino/citadel/shared/PROTOCOL.md"
ONLINE_GITHUB="https://github.com/randomchaos7800-hub"
LOCAL_FORGE_URL="http://cha0tikhome.tailc83c25.ts.net:3002/"
LOCAL_FORGE_ROOT="/var/lib/forgejo/data/forgejo-repositories"
LOCAL_FORGE_ORG="cha0tik"


if [ ! -x "$CODEX_BIN" ]; then
  echo "codex binary not found at $CODEX_BIN" >&2
  exit 1
fi

exec env HOME="$HOME_ROOT" CODEX_HOME="$CODEX_HOME_ROOT" REAL_HOME="$HOME_ROOT" DINO_HOME="$HOME_ROOT" CITADEL_ROOT="$CITADEL_ROOT" CITADEL_PROTOCOL="$CITADEL_PROTOCOL" ONLINE_GITHUB="$ONLINE_GITHUB" LOCAL_FORGE_URL="$LOCAL_FORGE_URL" LOCAL_FORGE_ROOT="$LOCAL_FORGE_ROOT" LOCAL_FORGE_ORG="$LOCAL_FORGE_ORG" "$CODEX_BIN" exec \
  --profile embedded \
  --cd "$HOME_ROOT" \
  --skip-git-repo-check \
  --dangerously-bypass-approvals-and-sandbox \
  "$@"
