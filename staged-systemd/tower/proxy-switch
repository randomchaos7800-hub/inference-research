#!/bin/bash
# proxy-switch genesis | nemotron | aeon | openrouter
# Switches the local-proxy backend and manages the corresponding local service.
set -euo pipefail

BACKEND="${1:-}"
CONFIG="/home/dino/local-proxy/config.toml"
PROXY_URL="http://localhost:8010"

declare -A SERVICE_FOR=(
  [genesis]="vllm-backend.service"
  [nemotron]="nemotron.service"
  [aeon]="vllm-aeon.service"
)

MANAGED_SERVICES=(
  "nemotron.service"
  "vllm-backend.service"
  "vllm-aeon.service"
)

usage() {
  echo "Usage: proxy-switch <backend>"
  echo "Backends: genesis | nemotron | aeon | openrouter"
  current=$(grep '^active = ' "$CONFIG" | sed 's/^active = \"//; s/\"$//')
  echo "Current: $current"
}

switch_config() {
  local target="$1"
  sed -i "s/^active = .*/active = \"$target\"/" "$CONFIG"
}

stop_other_services() {
  local keep="${1:-}"
  local svc
  for svc in "${MANAGED_SERVICES[@]}"; do
    if [[ "$svc" != "$keep" ]]; then
      systemctl --user stop "$svc" >/dev/null 2>&1 || true
    fi
  done
}

wait_for_port() {
  local port="$1"
  for _ in $(seq 1 60); do
    if ss -ltn 2>/dev/null | grep -q ":${port} "; then
      return 0
    fi
    sleep 2
  done
  return 1
}

wait_for_proxy() {
  for _ in $(seq 1 30); do
    if curl -sf "$PROXY_URL/health" >/dev/null 2>&1; then
      return 0
    fi
    sleep 1
  done
  return 1
}

if [[ -z "$BACKEND" ]]; then
  usage
  exit 0
fi

if ! grep -q "^\[backends\.$BACKEND\]" "$CONFIG"; then
  echo "Unknown backend: $BACKEND" >&2
  echo "Available: $(grep '^\[backends\.' "$CONFIG" | sed 's/\[backends\.\(.*\)\]/\1/' | tr '\n' ' ')" >&2
  exit 1
fi

if [[ "$BACKEND" == "openrouter" ]]; then
  stop_other_services
  switch_config "$BACKEND"
  systemctl --user restart local-proxy.service
  wait_for_proxy
else
  target_service="${SERVICE_FOR[$BACKEND]:-}"
  if [[ -z "$target_service" ]]; then
    echo "Backend '$BACKEND' is not mapped to a managed local service." >&2
    exit 1
  fi

  stop_other_services "$target_service"
  systemctl --user reset-failed "$target_service" >/dev/null 2>&1 || true
  systemctl --user start "$target_service"

  case "$BACKEND" in
    genesis|nemotron) wait_for_port 8022 ;;
    aeon) wait_for_port 8023 ;;
  esac

  switch_config "$BACKEND"
  systemctl --user restart local-proxy.service
  wait_for_proxy
fi

echo "Switched -> $BACKEND"
curl -sf "$PROXY_URL/active" | python3 -c "import sys,json; d=json.load(sys.stdin); print(f'  active: {d[\"active\"]}  ->  {d[\"url\"]}  ({d.get(\"model_effective\") or d.get(\"model_config\") or \"unknown\"})')"
